# --- Server ---
PORT=8787
FRONTEND_ORIGIN=http://localhost:5173

# --- Gemini (Google AI Studio) ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Use a Flash model to stay on the free tier
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Option: Add DATABASE_URL connection string to automate database tables setup
DATABASE_URL=

# --- Meta Graph API (Facebook Page + Instagram Business) ---
# Create an app at https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_BUSINESS_ACCOUNT_ID=

# --- LinkedIn API ---
# Create an app at https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# --- Puppeteer assisted posting ---
# Path to a persistent Chrome profile so you only log into Facebook once.
# Using YOUR real logged-in browser profile is safer than a fresh automated login.
PUPPETEER_USER_DATA_DIR=./browser-profile
# Run visibly (not headless) so you stay in control and can click "Post" yourself.
PUPPETEER_HEADLESS=false
